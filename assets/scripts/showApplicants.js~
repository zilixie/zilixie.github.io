//build the applicants list
function buildList() {
    var url;
    var sub_url  = 'applicants';
    var opt = document.getElementById('selectStatus').value;
    if (opt == 'All') {
        url = sub_url;
    }
    else {
        url = sub_url + "?status=" + opt;
    }
    $.get(url, function (data) {
	$('#myTable tr').remove();
        let parent = $('#myTable');
	let applicantObj = JSON.parse(data);
	let taArray = applicantObj.tas;
        parent.append('<tr><th>' + 'GivenName' + 
                      '</th><th>' + 'Family Name'+ 
                      '</th><th>' + 'Status'+ 
                      '</th><th>' + 'Year');

        for(let i = 0; i < taArray.length; i++) {
            let obj = $('<tr>');
            obj.append($('<td>').text(taArray[i].givenname));
            obj.append($('<td>').text(taArray[i].familyname));
            obj.append($('<td>').text(taArray[i].status));
            obj.append($('<td>').text(taArray[i].year));
            parent.append(obj);
        }
    });
}

//build the courses list
function buildCourses(result) {
        var i;
        var j;
	$('#myTable3 tr').remove();
        let parent = $('#myTable3');
	let courseArray = result.courses;
        parent.append('<tr><th>' + 'Course' + 
                      '</th><th>' + 'Ranking'+ 
                      '</th><th>' + 'Experience'+ 
                      '</th><th>' + 'Status'+ 
                      '</th><th>' + 'Given Name' +
                      '</th><th>' + 'Family Name');

        

        for(i = 0; i < courseArray.length; i++) {
            for(j = 0; j < courseArray[i]["tas"].length; j++) {
                let obj = $('<tr>');
                obj.append($('<td>').text(courseArray[i].code));
                obj.append($('<td>').text(courseArray[i]["tas"][j].ranking));
                obj.append($('<td>').text(courseArray[i]["tas"][j].experience));
                obj.append($('<td>').text(courseArray[i]["tas"][j].status));
                obj.append($('<td>').text(courseArray[i]["tas"][j].givenname));
                obj.append($('<td>').text(courseArray[i]["tas"][j].familyname));
                parent.append(obj);
            }
        }
}

//search applicant by family name
function showByFname(result) {
    let parent = $('#myTable2');
    $('#myTable2 li').remove();
    $('#myTable2 hr').remove();
    $('#myTable2 ul').remove();
    var taArray = result.tas;
    console.log(taArray[0].givenname);
    for(let i = 0; i < taArray.length; i++) {
        parent.append($('<li>').text('Given name:' + taArray[i].givenname));
        parent.append($('<li>').text('Family name:' + taArray[i].familyname));
        parent.append($('<li>').text('Student number:' + taArray[i].stunum));
        parent.append($('<li>').text('Status:' + taArray[i].status));
        parent.append($('<li>').text('Year:' + taArray[i].year));
        parent.append($('<li>').text('Courses:'));
        var courses = result['tas'][0]['courses'];
        //console.log(courses);
        //console.log(courses.length);
        //console.log(courses[i].code);
        for (let j = 0; j < courses.length; j++) {
            let obj = $('<ul>');
            obj.append($('<li>').text('Code:' + courses[j].code));
            obj.append($('<li>').text('Rank:' + courses[j].rank));
            obj.append($('<li>').text('Experience:' + courses[j].experience));
            parent.append(obj);
            parent.append($('<hr width="50%" align="left">'));
        }
    }   
}


$(document).ready(function() {
    buildList();
    //search by family name
    $("#searchButton").click(function() {
        var fname = $("#fname").val();
        $.ajax({
            url:"/applicants?fname=" + fname,
            type:"GET",
            success: function(response) {
                var result = JSON.parse(response);
                showByFname(result);
                //console.log(result);
            }
        });
    });

    //search applicants by course
    $("#btn").click(function() {
        var c = $("#typeCourse").val();
        console.log(c);
        if (c != ""){
            $.ajax({
                url:"/courses?course=" + c,
                type:"GET",
                success: function(response) {
                    var result = JSON.parse(response);
                    buildCourses(result);
                    //console.log(result);
                }
            });
        }
        else {
            $.ajax({
                url:"/courses",
                type:"GET",
                success: function(response) {
                    var result = JSON.parse(response);
                    buildCourses(result);
                    //console.log(result);
                }
            });
        }
    });


    //add the applicant
    $("#addButton").click(function (e) {
        e.preventDefault();
        console.log($('form').serialize());
        
        var opt = document.getElementById('select').value;
        var data = 'status=' +opt +'&'+ $('form').serialize();
        console.log(data);
        $.ajax({
            url: "/applicants",
            type: "POST",
            data: data,
            success: function(response){
                console.log(response);
                if (response == "Success"){
                    alert("You have successfully add the applicant!");
                    location.reload(true);
                }else if (response == "Error: duplicate student number"){
                    alert("Error: duplicate student number");
                }else if (response == "Error: empty field"){
                    alert("Error: empty field");
                }
            }
        });
    });


    //add more courses
    $("#addCourse").click(function () {
        let parent = $('#addinput');
        let label = $('<label>');
        let span = $('<span>')
        span.text('Code:');
        span.attr("class", "label");

        let input = $('<input>');
        input.attr("type", "text");
        input.attr("name", "code");

        label.append(span);
        label.append(input);
        parent.append(label);


        let parent1 = $('#addinput');
        let label1 = $('<label>');
        let span1 = $('<span>')
        span1.text('Rank:');
        span1.attr("class", "label");

        let input1 = $('<input>');
        input1.attr("type", "text");
        input1.attr("name", "rank");
       

        label1.append(span1);
        label1.append(input1);
        parent1.append(label1);


        let parent2 = $('#addinput');
        let label2 = $('<label>');
        let span2 = $('<span>')
        span2.text('Experience:');
        span2.attr("class", "label");

        let input2 = $('<input>');
        input2.attr("type", "text");
        input2.attr("name", "experience");

        label2.append(span2);
        label2.append(input2);
        parent2.append(label2);

    });





    //remove by family name
    $("#fnrmButton").click(function (e) {
        let fname = $('#removefname').val();
        //console.log(fname);
        $.ajax({
            url: '/applicants?fname=' + fname,
            type: 'DELETE',
            success: function(response){
                //console.log(response);
                if (response == "Success"){
                    alert("You have successfully removed the applicant!");
                    location.reload(true);
                }else if (response == "Error: no such student"){
                    alert("Error: no such student");
                }
            }
        });

    });


    //remove by student number
    $("#snrmButton").click(function (e) {
        let stunum = $('#removesnum').val();
        //console.log(stunum);
        $.ajax({
            url: '/applicants?stunum=' + stunum,
            type: 'DELETE',
            success: function(response){
                if (response == "Success"){
                    alert("You have successfully removed the applicant!");
                    location.reload(true);
                }else if (response == "Error: no such student"){
                    alert("Error: no such student");
                }
            }
        });
    });



});
